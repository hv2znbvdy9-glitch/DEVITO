$ForbiddenPatterns = @(
    "takeown",
    "icacls",
    "set-acl",
    "sc.exe\s+sdset",
    "bcdedit",
    "diskpart",
    "format",
    "reg\s+delete",
    "remove-item\s+-recurse",
    "trustedinstaller",
    "sebackupprivilege",
    "serestoreprivilege"
)

$ScriptText = Get-Content -Path $MyInvocation.MyCommand.Path -Raw

foreach ($pattern in $ForbiddenPatterns) {
    if ($ScriptText -match $pattern) {
        Write-Error "SICHERHEITSSTOPP: Verbotenes Muster erkannt: $pattern"
        exit 999
    }
}


function Assert-SafePath {
    param([string]$Path)

    $Blocked = @(
        "C:\Windows\System32\config",
        "C:\Windows\Boot",
        "C:\Windows\WinSxS",
        "HKLM:\SYSTEM",
        "HKLM:\SECURITY"
    )

    foreach ($b in $Blocked) {
        if ($Path -like "$b*") {
            Write-Error "SICHERHEITSSTOPP: Zugriff auf geschützten Pfad blockiert: $Path"
            exit 998
        }
    }
}


