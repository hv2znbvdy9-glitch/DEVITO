Write-Host "HTML: $HtmlPath" -ForegroundColor Green

@echo off
setlocal EnableExtensions EnableDelayedExpansion
title AVA 01610 NACHHALL - ULTIMATE ADMIN LOCKDOWN
color 0A

:: =========================
::  CONFIG / PATHS
:: =========================
set "BASE=C:\AVA01610_NACHHALL"
set "TS=%DATE:~-4%%DATE:~3,2%%DATE:~0,2%_%TIME:~0,2%%TIME:~3,2%%TIME:~6,2%"
set "TS=%TS: =0%"
set "LOGDIR=%BASE%\logs_%TS%"
set "LOG=%LOGDIR%\lockdown.log"

if not exist "%LOGDIR%" mkdir "%LOGDIR%" >nul 2>&1

echo ================================================== | tee "%LOG%"
echo  AVA 01610 NACHHALL - ULTIMATE ADMIN LOCKDOWN      | tee -a "%LOG%"
echo  Timestamp: %TS%                                  | tee -a "%LOG%"
echo ================================================== | tee -a "%LOG%"
echo.

:: tee helper (fallback if tee missing)
:: If "tee" doesn't exist, lines still go to console; logs written via extra echoes below.
where tee >nul 2>&1
if errorlevel 1 (
  echo [INFO] "tee" nicht gefunden. Logging erfolgt in Dateien + Konsole.>>"%LOG%"
)

:: =========================
::  SAFETY: CREATE RESTORE POINT (best effort)
:: =========================
echo [0] Wiederherstellungspunkt (best effort)...
echo [0] Restore Point attempt>>"%LOG%"
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
  "try { Enable-ComputerRestore -Drive 'C:\' -ErrorAction SilentlyContinue; Checkpoint-Computer -Description 'AVA01610_NACHHALL_Lockdown' -RestorePointType 'MODIFY_SETTINGS' -ErrorAction SilentlyContinue } catch {}" ^
  >>"%LOG%" 2>&1

:: =========================
::  1) INVENTORY / FORENSIC SNAPSHOT
:: =========================
echo [1] Snapshot/Forensik: Benutzer, Admins, Dienste, Tasks, Autostart, Netzwerk...
echo [1] Snapshot start>>"%LOG%"

echo --- USERS --- > "%LOGDIR%\users.txt"
net user >> "%LOGDIR%\users.txt" 2>&1

echo --- ADMINS --- > "%LOGDIR%\admins.txt"
net localgroup administrators >> "%LOGDIR%\admins.txt" 2>&1

echo --- LOCAL SECURITY POLICY (export) --- > "%LOGDIR%\secpol_export.txt"
secedit /export /cfg "%LOGDIR%\secpol.cfg" /areas SECURITYPOLICY USER_RIGHTS >> "%LOGDIR%\secpol_export.txt" 2>&1

echo --- SERVICES (running) --- > "%LOGDIR%\services_running.txt"
sc query type= service state= all > "%LOGDIR%\services_all.txt" 2>&1
sc query type= service state= running > "%LOGDIR%\services_running.txt" 2>&1

echo --- SCHEDULED TASKS --- > "%LOGDIR%\scheduled_tasks.txt"
schtasks /query /fo LIST /v > "%LOGDIR%\scheduled_tasks.txt" 2>&1

echo --- STARTUP (WMIC) --- > "%LOGDIR%\startup_wmic.txt"
wmic startup get Caption,Command,Location,User > "%LOGDIR%\startup_wmic.txt" 2>&1

echo --- STARTUP (Registry Run keys) --- > "%LOGDIR%\startup_registry.txt"
reg query "HKLM\Software\Microsoft\Windows\CurrentVersion\Run" /s >> "%LOGDIR%\startup_registry.txt" 2>&1
reg query "HKCU\Software\Microsoft\Windows\CurrentVersion\Run" /s >> "%LOGDIR%\startup_registry.txt" 2>&1

echo --- NETWORK CONNECTIONS --- > "%LOGDIR%\netstat_ano.txt"
netstat -ano > "%LOGDIR%\netstat_ano.txt" 2>&1

echo --- FIREWALL EXPORT --- > "%LOGDIR%\firewall_export.txt"
netsh advfirewall export "%LOGDIR%\firewall.wfw" > "%LOGDIR%\firewall_export.txt" 2>&1

echo --- INSTALLED SOFTWARE (WMIC) --- > "%LOGDIR%\installed_software.txt"
wmic product get Name,Version,Vendor > "%LOGDIR%\installed_software.txt" 2>&1

echo --- HOSTS FILE --- > "%LOGDIR%\hosts.txt"
type "%SystemRoot%\System32\drivers\etc\hosts" > "%LOGDIR%\hosts.txt" 2>&1

echo [1] Snapshot done>>"%LOG%"

:: =========================
::  2) ACCOUNT / PASSWORD POLICY HARDENING
:: =========================
echo [2] Passwort-/Account-Policy Hardening...
echo [2] Password policy>>"%LOG%"

:: Stronger local account policy
net accounts /minpwlen:14 >nul 2>&1
net accounts /maxpwage:30 >nul 2>&1
net accounts /minpwage:1 >nul 2>&1
net accounts /uniquepw:10 >nul 2>&1
net accounts /lockoutthreshold:5 >nul 2>&1
net accounts /lockoutduration:30 >nul 2>&1
net accounts /lockoutwindow:30 >nul 2>&1

:: Disable Guest
net user guest /active:no >nul 2>&1

:: =========================
::  3) DISABLE REMOTE ACCESS / REMOTE MGMT (RDP, WinRM, Remote Registry)
:: =========================
echo [3] Remotezugriffe deaktivieren (RDP/WinRM/RemoteRegistry)...
echo [3] Remote off>>"%LOG%"

:: RDP off
reg add "HKLM\SYSTEM\CurrentControlSet\Control\Terminal Server" /v fDenyTSConnections /t REG_DWORD /d 1 /f >>"%LOG%" 2>&1
sc stop TermService >>"%LOG%" 2>&1
sc config TermService start= disabled >>"%LOG%" 2>&1

:: Remote Registry off
sc stop RemoteRegistry >>"%LOG%" 2>&1
sc config RemoteRegistry start= disabled >>"%LOG%" 2>&1

:: WinRM off (remote powershell / management)
sc stop WinRM >>"%LOG%" 2>&1
sc config WinRM start= disabled >>"%LOG%" 2>&1

:: Disable Remote Assistance
reg add "HKLM\SYSTEM\CurrentControlSet\Control\Remote Assistance" /v fAllowToGetHelp /t REG_DWORD /d 0 /f >>"%LOG%" 2>&1

:: =========================
::  4) FIREWALL HARDENING
:: =========================
echo [4] Firewall Hardening (Inbound block, Outbound allow)...
echo [4] Firewall>>"%LOG%"

netsh advfirewall set allprofiles state on >>"%LOG%" 2>&1
netsh advfirewall set allprofiles firewallpolicy blockinbound,allowoutbound >>"%LOG%" 2>&1
netsh advfirewall set allprofiles settings inboundusernotification enable >>"%LOG%" 2>&1

:: Optional: block common remote admin ports inbound explicitly (defense-in-depth)
netsh advfirewall firewall add rule name="Block RDP In" dir=in action=block protocol=TCP localport=3389 >>"%LOG%" 2>&1
netsh advfirewall firewall add rule name="Block WinRM In" dir=in action=block protocol=TCP localport=5985,5986 >>"%LOG%" 2>&1
netsh advfirewall firewall add rule name="Block SMB In" dir=in action=block protocol=TCP localport=445 >>"%LOG%" 2>&1

:: =========================
::  5) SCRIPTING / MACRO / LOLBINS HARDENING
:: =========================
echo [5] Script-Engines deaktivieren (WSH) + PowerShell Script Restriction...
echo [5] Scripting>>"%LOG%"

:: Windows Script Host disable (.vbs/.js via wscript/cscript)
reg add "HKLM\Software\Microsoft\Windows Script Host\Settings" /v Enabled /t REG_DWORD /d 0 /f >>"%LOG%" 2>&1

:: PowerShell: restrict scripts (still allows interactive PS; scripts blocked)
powershell -NoProfile -ExecutionPolicy Bypass -Command "Set-ExecutionPolicy Restricted -Scope LocalMachine -Force" >>"%LOG%" 2>&1

:: Office macro hardening (common pivot) - sets "Disable all macros without notification" for current machine policy
reg add "HKLM\Software\Policies\Microsoft\Office\16.0\Word\Security" /v VBAWarnings /t REG_DWORD /d 4 /f >>"%LOG%" 2>&1
reg add "HKLM\Software\Policies\Microsoft\Office\16.0\Excel\Security" /v VBAWarnings /t REG_DWORD /d 4 /f >>"%LOG%" 2>&1
reg add "HKLM\Software\Policies\Microsoft\Office\16.0\PowerPoint\Security" /v VBAWarnings /t REG_DWORD /d 4 /f >>"%LOG%" 2>&1

:: Disable Autorun/Autoplay (USB infection vector)
reg add "HKLM\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" /v NoDriveTypeAutoRun /t REG_DWORD /d 255 /f >>"%LOG%" 2>&1

:: =========================
::  6) BLOCK UNIX-LIKE SHELLS / WSL
:: =========================
echo [6] WSL/VMPlatform deaktivieren + Bash-Prozesse beenden...
echo [6] WSL off>>"%LOG%"

dism /online /disable-feature /featurename:Microsoft-Windows-Subsystem-Linux /norestart >>"%LOG%" 2>&1
dism /online /disable-feature /featurename:VirtualMachinePlatform /norestart >>"%LOG%" 2>&1

taskkill /IM wsl.exe /F >>"%LOG%" 2>&1
taskkill /IM bash.exe /F >>"%LOG%" 2>&1
taskkill /IM sh.exe /F >>"%LOG%" 2>&1

:: =========================
::  7) SMB / NETWORK HARDENING (LLMNR, NetBIOS, WPAD)
:: =========================
echo [7] Netzwerk-Härtung (SMB1 aus, SMB Encryption an, LLMNR/WPAD/NetBIOS aus)...
echo [7] Network hardening>>"%LOG%"

:: SMB hardening (PowerShell required)
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
 "try { Set-SmbServerConfiguration -EnableSMB1Protocol $false -Force | Out-Null } catch {}" >>"%LOG%" 2>&1
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
 "try { Set-SmbServerConfiguration -EncryptData $true -Force | Out-Null } catch {}" >>"%LOG%" 2>&1

:: LLMNR disable
reg add "HKLM\Software\Policies\Microsoft\Windows NT\DNSClient" /v EnableMulticast /t REG_DWORD /d 0 /f >>"%LOG%" 2>&1

:: WPAD disable (proxy auto-detect)
reg add "HKLM\Software\Policies\Microsoft\Windows\CurrentVersion\Internet Settings" /v EnableAutoproxyResultCache /t REG_DWORD /d 0 /f >>"%LOG%" 2>&1
reg add "HKLM\Software\Microsoft\Windows\CurrentVersion\Internet Settings\WinHttp" /v AutoDetect /t REG_DWORD /d 0 /f >>"%LOG%" 2>&1

:: NetBIOS over TCP/IP disable (best effort: all interfaces)
for /f "tokens=*" %%i in ('reg query "HKLM\SYSTEM\CurrentControlSet\Services\NetBT\Parameters\Interfaces" 2^>nul ^| findstr /i "Tcpip_"') do (
  reg add "%%i" /v NetbiosOptions /t REG_DWORD /d 2 /f >>"%LOG%" 2>&1
)

:: =========================
::  8) DEFENDER HARDENING + ASR RULES
:: =========================
echo [8] Microsoft Defender: Realtime + ASR aktivieren...
echo [8] Defender/ASR>>"%LOG%"

powershell -NoProfile -ExecutionPolicy Bypass -Command ^
 "try { Set-MpPreference -DisableRealtimeMonitoring $false } catch {}" >>"%LOG%" 2>&1

:: Enable cloud protection & sample submission (more detection)
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
 "try { Set-MpPreference -MAPSReporting Advanced; Set-MpPreference -SubmitSamplesConsent 3 } catch {}" >>"%LOG%" 2>&1

:: Attack Surface Reduction rules (common high-value set)
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
 "$rules=@(
 'D4F940AB-401B-4EFC-AADC-AD5F3C50688A',  # Block Office from creating child processes
 '3B576869-A4EC-4529-8536-B80A7769E899',  # Block Office from creating executable content
 '75668C1F-73B5-4CF0-BB93-3ECF5CB7CC84',  # Block Office from injecting code
 'BE9BA2D9-53EA-4CDC-84E5-9B1EEEE46550',  # Block executable content from email/webmail
 'D3E037E1-3EB8-44C8-A917-57927947596D',  # Block credential stealing from LSASS
 '5BEB7EFE-FD9A-4556-801D-275E5FFC04CC',  # Block execution of potentially obfuscated scripts
 '92E97FA1-2EDF-4476-BDD6-9DD0B4DDDC7B'   # Block Win32 API calls from Office macros
 );
 try {
   Add-MpPreference -AttackSurfaceReductionRules_Ids $rules -AttackSurfaceReductionRules_Actions (1,1,1,1,1,1,1)
 } catch {}" >>"%LOG%" 2>&1

:: =========================
::  9) APPLOCKER (DENY RULES FOR COMMON SHELLS/SCRIPTS) - best effort
:: =========================
echo [9] AppLocker: Deny-Regeln für Bash/WSL/Script-Hosts (best effort)...
echo [9] AppLocker>>"%LOG%"

:: Ensure Application Identity service (needed for AppLocker enforcement)
sc config AppIDSvc start= auto >>"%LOG%" 2>&1
sc start AppIDSvc >>"%LOG%" 2>&1

:: Create minimal AppLocker policy (default allow Windows) + explicit denies
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
"try {
  $pol = New-AppLockerPolicy -DefaultRule -RuleType Executable,Script,WindowsInstaller;
  $deny = @('bash.exe','sh.exe','wsl.exe','wscript.exe','cscript.exe');
  foreach($d in $deny){
    $r = New-AppLockerFileRule -RuleType Executable -User 'Everyone' -Action Deny -Name ('Deny_'+$d) -FilePath ('*\'+$d);
    $pol.RuleCollections[0].Rules.Add($r) | Out-Null
  }
  Set-AppLockerPolicy -PolicyObject $pol -Merge -ErrorAction SilentlyContinue | Out-Null
} catch {}" >>"%LOG%" 2>&1

:: =========================
::  10) AUDITING: LOGON / POLICY CHANGES / PROCESS CREATION (useful for intrusion)
:: =========================
echo [10] Auditing aktivieren (Logon/Policy/Process Creation)...
echo [10] Auditing>>"%LOG%"

auditpol /set /category:"Logon/Logoff" /success:enable /failure:enable >>"%LOG%" 2>&1
auditpol /set /category:"Account Logon" /success:enable /failure:enable >>"%LOG%" 2>&1
auditpol /set /category:"Account Management" /success:enable /failure:enable >>"%LOG%" 2>&1
auditpol /set /category:"Policy Change" /success:enable /failure:enable >>"%LOG%" 2>&1
auditpol /set /category:"System" /success:enable /failure:enable >>"%LOG%" 2>&1
auditpol /set /subcategory:"Process Creation" /success:enable /failure:enable >>"%LOG%" 2>&1

:: Enable command line in process creation events (Event ID 4688 includes cmdline)
reg add "HKLM\Software\Microsoft\Windows\CurrentVersion\Policies\System\Audit" /v ProcessCreationIncludeCmdLine_Enabled /t REG_DWORD /d 1 /f >>"%LOG%" 2>&1

:: =========================
::  11) POST-CHECKS / REPORT
