echo [11] Post-Checks: aktive Verbindungen, verdächtige Dienste/Tasks quick scan...
echo [11] Post checks>>"%LOG%"

netstat -ano > "%LOGDIR%\netstat_ano_after.txt" 2>&1
schtasks /query /fo LIST /v > "%LOGDIR%\scheduled_tasks_after.txt" 2>&1
sc query type= service state= running > "%LOGDIR%\services_running_after.txt" 2>&1
wevtutil qe Security /q:"*[System[(EventID=4624 or EventID=4625)]]" /c:50 /f:text > "%LOGDIR%\security_logon_last50.txt" 2>&1

:: Defender quick scan (best effort)
powershell -NoProfile -ExecutionPolicy Bypass -Command "try { Start-MpScan -ScanType QuickScan } catch {}" >>"%LOG%" 2>&1

:: =========================
::  DONE
:: =========================
echo.
