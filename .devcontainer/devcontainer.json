foreach ($id in $ASRRules.Keys) {
    Add-MpPreference -AttackSurfaceReductionRules_Ids $id `
                     -AttackSurfaceReductionRules_Actions $ASRRules[$id] `
                     -ErrorAction SilentlyContinue
}

# ==========================================================
# ?? DNS & BROWSER HÄRTUNG
# ==========================================================

# DNS Cache Hardening
Set-ItemProperty `
  "HKLM:\SYSTEM\CurrentControlSet\Services\Dnscache\Parameters" `
  -Name MaxNegativeCacheTtl -Value 0 -Force

# SmartScreen
Set-ItemProperty `
  "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer" `
  -Name SmartScreenEnabled -Value "RequireAdmin" -Force

# Edge Tracking aus
New-Item "HKLM:\SOFTWARE\Policies\Microsoft\Edge" -Force | Out-Null
Set-ItemProperty `
  "HKLM:\SOFTWARE\Policies\Microsoft\Edge" `
  -Name TrackingPrevention -Value 3 -Force

# ==========================================================
# ?? EVENT-LOG ÜBERWACHUNG (Angriffsindikatoren)
# ==========================================================
$Events = Get-WinEvent -FilterHashtable @{
    LogName='Security'
    Id=4625,4688
    StartTime=(Get-Date).AddMinutes(-5)
} -ErrorAction SilentlyContinue

if ($Events) {
    Log "?? Sicherheitsereignisse erkannt: $($Events.Count)"
}

# ==========================================================
# ?? WINGET (sanft, kein Zwang)
# ==========================================================
Start-Process "winget" `
  -ArgumentList "upgrade --all --silent --accept-source-agreements --accept-package-agreements" `
  -WindowStyle Hidden -ErrorAction SilentlyContinue

# ==========================================================
# ?? SCHEDULED TASK (60 SEKUNDEN)
# ==========================================================
if (-not (Get-ScheduledTask -TaskName $TaskName -ErrorAction SilentlyContinue)) {

    $Action = New-ScheduledTaskAction -Execute "powershell.exe" `
        -Argument "-NoProfile -ExecutionPolicy Bypass -File `"$ScriptPath`""

    $Trigger = New-ScheduledTaskTrigger -Once -At (Get-Date) `
        -RepetitionInterval (New-TimeSpan -Seconds 60)

    $Principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -RunLevel Highest

    Register-ScheduledTask `
        -TaskName $TaskName `
        -Action $Action `
        -Trigger $Trigger `
        -Principal $Principal | Out-Null

    Log "Scheduled Task installiert (60 Sekunden)"
}

exit 0




#requires -Version 5.1
<#
ELITE-Scan.ps1 (Defensive / Read-only)
- Visual Dashboard in Console
- Risk score + short findings
- HTML report export + optional auto-open
#>

Set-StrictMode -Version Latest
$ErrorActionPreference = "SilentlyContinue"

# ----------------------- helpers -----------------------
function Test-Admin {
  $id = [Security.Principal.WindowsIdentity]::GetCurrent()
  $p  = New-Object Security.Principal.WindowsPrincipal($id)
  return $p.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

function Write-Header($title) {
  $line = ("=" * 78)
  Write-Host ""
  Write-Host $line -ForegroundColor DarkCyan
  Write-Host ("  " + $title) -ForegroundColor Cyan
  Write-Host $line -ForegroundColor DarkCyan
}

function New-Finding {
  param(
    [ValidateSet("INFO","LOW","MED","HIGH","CRIT")] [string]$Severity,
    [string]$Title,
    [string]$Details
  )
  [pscustomobject]@{
    Time     = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    Severity = $Severity
    Title    = $Title
    Details  = $Details
  }
}

function Add-Finding([ref]$Findings, $Finding) {
  $Findings.Value += $Finding
}

function Severity-Score([string]$sev) {
  switch ($sev) {
    "INFO" { 0 }
    "LOW"  { 5 }
    "MED"  { 15 }
    "HIGH" { 30 }
    "CRIT" { 50 }
    default { 0 }
  }
}

function Short($s, $max=140) {
  if ([string]::IsNullOrWhiteSpace($s)) { return "" }
  if ($s.Length -le $max) { return $s }
  return $s.Substring(0, $max) + "â€¦"
}

function Safe-Run($scriptblock) {
  try { & $scriptblock } catch { $null }
}

# ----------------------- config -----------------------
$StartTime = Get-Date
$IsAdmin = Test-Admin
$Computer = $env:COMPUTERNAME
$User = "$env:USERDOMAIN\$env:USERNAME"

$SuspiciousProcNames = @(
  "powershell.exe","pwsh.exe","cmd.exe","wscript.exe","cscript.exe","mshta.exe",
  "rundll32.exe","regsvr32.exe","bitsadmin.exe","certutil.exe","wmic.exe"
)

# report paths
$OutDir = Join-Path $env:USERPROFILE "Desktop\ELITE_SCAN_REPORT"
New-Item -ItemType Directory -Path $OutDir -Force | Out-Null
$Stamp = Get-Date -Format "yyyyMMdd_HHmmss"
$JsonPath = Join-Path $OutDir "elite_scan_$Stamp.json"
$HtmlPath = Join-Path $OutDir "elite_scan_$Stamp.html"
$TxtPath  = Join-Path $OutDir "elite_scan_$Stamp.txt"

# ----------------------- collect -----------------------
$Findings = @()

Write-Header "ELITE SCAN â€” $Computer â€” $User â€” $(Get-Date -Format 'yyyy-MM-dd HH:mm')"
Write-Host ("Admin: " + ($IsAdmin ? "YES" : "NO (einige Checks eingeschrÃ¤nkt)")) -ForegroundColor Yellow
Write-Host ("Report: $OutDir") -ForegroundColor DarkGray

# 1) Defender status + last threats
$Defender = Safe-Run { Get-MpComputerStatus }
if ($Defender) {
  if (-not $Defender.RealTimeProtectionEnabled) {
    Add-Finding ([ref]$Findings) (New-Finding HIGH "Defender Echtzeitschutz AUS" "RealTimeProtectionEnabled = False")
  } else {
    Add-Finding ([ref]$Findings) (New-Finding INFO "Defender Echtzeitschutz AN" "OK")
  }

  if ($Defender.IsTamperProtected -eq $false) {
    Add-Finding ([ref]$Findings) (New-Finding MED "Tamper Protection AUS" "Empfohlen: Tamper Protection aktivieren")
  }

  Add-Finding ([ref]$Findings) (New-Finding INFO "Defender Engine" ("AMProductVersion: {0}" -f $Defender.AMProductVersion))
} else {
  Add-Finding ([ref]$Findings) (New-Finding MED "Defender Status nicht auslesbar" "Get-MpComputerStatus fehlgeschlagen (Policy/Edition?)")
}

$Threats = Safe-Run { Get-MpThreatDetection | Sort-Object InitialDetectionTime -Descending | Select-Object -First 15 }
if ($Threats) {
  $recent = $Threats | Select-Object -First 1
  Add-Finding ([ref]$Findings) (New-Finding INFO "Letzte Defender-Erkennung" ("{0} â€” {1} â€” StatusID {2}" -f $recent.InitialDetectionTime, $recent.ThreatID, $recent.ThreatStatusID))
}

# 2) Interactive sessions (RDP/console)
$SessionsText = Safe-Run { (quser 2>$null) }
if ($SessionsText) {
  # Flag suspicious: more than 1 active session
  $activeCount = ($SessionsText | Select-String "Active").Count
  if ($activeCount -gt 1) {
    Add-Finding ([ref]$Findings) (New-Finding MED "Mehrere aktive Benutzer-Sessions" ("Active Sessions: $activeCount`n" + (Short ($SessionsText | Out-String) 300)))
  } else {
    Add-Finding ([ref]$Findings) (New-Finding INFO "Benutzer-Sessions" ("OK`n" + (Short ($SessionsText | Out-String) 260)))
  }
} else {
  Add-Finding ([ref]$Findings) (New-Finding INFO "Benutzer-Sessions" "quser nicht verfÃ¼gbar (kein Terminaldienst / Rechte)")
}

# 3) Network connections (ESTABLISHED) + owning process
$Conns = Safe-Run { Get-NetTCPConnection -State Established | Select-Object -First 200 }
if ($Conns) {
  $ConnRows = foreach ($c in $Conns) {
    $p = Safe-Run { Get-Process -Id $c.OwningProcess -ErrorAction SilentlyContinue }
    [pscustomobject]@{
      Local  = "{0}:{1}" -f $c.LocalAddress, $c.LocalPort
      Remote = "{0}:{1}" -f $c.RemoteAddress, $c.RemotePort
      PID    = $c.OwningProcess
      Proc   = if ($p) { $p.ProcessName + ".exe" } else { "?" }
    }
  }

  $susp = $ConnRows | Where-Object { $SuspiciousProcNames -contains $_.Proc } | Select-Object -First 20
  if ($susp) {
    Add-Finding ([ref]$Findings) (New-Finding MED "VerdÃ¤chtige Prozesse mit aktiven Verbindungen" ((Short ($susp | Format-Table -AutoSize | Out-String) 400)))
  } else {
    Add-Finding ([ref]$Findings) (New-Finding INFO "Aktive Netzwerkverbindungen" ("ESTABLISHED: {0} (keine typischen Living-off-the-Land Tools mit Verbindungen gefunden)" -f $ConnRows.Count))
  }
} else {
  Add-Finding ([ref]$Findings) (New-Finding INFO "Netzwerkverbindungen" "Keine ESTABLISHED Verbindungen (oder Get-NetTCPConnection nicht verfÃ¼gbar)")
}

# 4) Scheduled tasks (non-Microsoft) + suspicious actions
$Tasks = Safe-Run { Get-ScheduledTask }
if ($Tasks) {
  $NonMs = $Tasks | Where-Object { $_.TaskPath -notlike "\Microsoft\*" }
  $SuspTasks = foreach ($t in $NonMs) {
    $info = Safe-Run { Get-ScheduledTaskInfo -TaskName $t.TaskName -TaskPath $t.TaskPath }
    $acts = $t.Actions | ForEach-Object { $_.Execute + " " + $_.Arguments }
    $actsStr = ($acts -join " | ")
    if ($actsStr -match "powershell|cmd|wscript|cscript|mshta|rundll32|regsvr32|bitsadmin|certutil") {
      [pscustomobject]@{
        Task   = ($t.TaskPath + $t.TaskName)
        RunAs  = $t.Principal.UserId
        Next   = $info.NextRunTime
        Action = Short $actsStr 260
      }
    }
  }

  if ($SuspTasks) {
    Add-Finding ([ref]$Findings) (New-Finding HIGH "Nicht-Microsoft Scheduled Tasks mit riskanten Actions" ((Short ($SuspTasks | Format-Table -AutoSize | Out-String) 500)))
  } else {
    Add-Finding ([ref]$Findings) (New-Finding INFO "Scheduled Tasks" ("Non-Microsoft: {0} â€” keine typischen LOLBins in Actions" -f ($NonMs.Count)))
  }
} else {
  Add-Finding ([ref]$Findings) (New-Finding INFO "Scheduled Tasks" "Get-ScheduledTask nicht verfÃ¼gbar")
}

# 5) Startup entries
$Startup = Safe-Run { Get-CimInstance Win32_StartupCommand | Select-Object Name, Command, Location, User }
if ($Startup) {
  $SusStartup = $Startup | Where-Object { $_.Command -match "powershell|cmd|wscript|cscript|mshta|rundll32|regsvr32" } | Select-Object -First 25
  if ($SusStartup) {
    Add-Finding ([ref]$Findings) (New-Finding MED "Autostart mit riskanten Befehlen" ((Short ($SusStartup | Format-Table -AutoSize | Out-String) 450)))
  } else {
    Add-Finding ([ref]$Findings) (New-Finding INFO "Autostart" ("EintrÃ¤ge: {0} â€” keine typischen LOLBins" -f $Startup.Count))
  }
}

# 6) Services: Auto-start + suspicious paths
$Services = Safe-Run { Get-CimInstance Win32_Service | Where-Object { $_.StartMode -eq "Auto" } }
if ($Services) {
  $SusSvc = $Services | Where-Object {
    ($_.PathName -match "AppData|Temp|\\Users\\") -or
    ($_.PathName -match "powershell|cmd|wscript|cscript|mshta|rundll32|regsvr32")
  } | Select-Object Name, State, StartName, PathName -First 20

  if ($SusSvc) {
    Add-Finding ([ref]$Findings) (New-Finding HIGH "Auto-Start Services mit verdÃ¤chtigen Pfaden/LOLbins" ((Short ($SusSvc | Format-Table -AutoSize | Out-String) 550)))
  } else {
    Add-Finding ([ref]$Findings) (New-Finding INFO "Services (Auto-Start)" ("Auto Services: {0} â€” keine offensichtlichen Red Flags" -f $Services.Count))
  }
}

# 7) Remote features quick glance: RDP / WinRM
$Rdp = Safe-Run { (Get-ItemProperty "HKLM:\System\CurrentControlSet\Control\Terminal Server").fDenyTSConnections }
if ($null -ne $Rdp) {
  if ($Rdp -eq 0) { Add-Finding ([ref]$Findings) (New-Finding MED "RDP ist aktiviert" "Wenn nicht benÃ¶tigt: deaktivieren (fDenyTSConnections=1)") }
  else { Add-Finding ([ref]$Findings) (New-Finding INFO "RDP" "Deaktiviert") }
}

$WinRM = Safe-Run { Get-Service WinRM }
if ($WinRM) {
  if ($WinRM.Status -eq "Running") {
    Add-Finding ([ref]$Findings) (New-Finding MED "WinRM lÃ¤uft" "Wenn nicht genutzt: stoppen/disable. Wenn genutzt: Firewall + Auth hÃ¤rten.")
  } else {
    Add-Finding ([ref]$Findings) (New-Finding INFO "WinRM" ("Status: {0}" -f $WinRM.Status))
  }
}

# 8) Proxy (common persistence / traffic redirect)
$Proxy = Safe-Run { netsh winhttp show proxy | Out-String }
if ($Proxy -and $Proxy -notmatch "Direct access") {
  Add-Finding ([ref]$Findings) (New-Finding MED "WinHTTP Proxy gesetzt" (Short $Proxy 350))
} else {
  Add-Finding ([ref]$Findings) (New-Finding INFO "WinHTTP Proxy" "Direct access (kein Proxy)") 
}

# 9) BitLocker / Geraeteverschluesselung Status
$BitlockerFindingDone = $false
$Blv = Safe-Run { Get-BitLockerVolume -MountPoint "C:" }
if ($Blv) {
  switch ($Blv.ProtectionStatus) {
    1 {
      Add-Finding ([ref]$Findings) (New-Finding INFO "BitLocker aktiv (Systemlaufwerk)" ("Status: {0}, Encryption: {1}%, LockStatus: {2}" -f $Blv.VolumeStatus, $Blv.EncryptionPercentage, $Blv.LockStatus))
      $BitlockerFindingDone = $true
    }
    0 {
      Add-Finding ([ref]$Findings) (New-Finding MED "BitLocker AUS (Systemlaufwerk)" ("Status: {0}, Encryption: {1}% -- Empfehlung: aktivieren" -f $Blv.VolumeStatus, $Blv.EncryptionPercentage))
      $BitlockerFindingDone = $true
    }
    default { }
  }
}

if (-not $BitlockerFindingDone) {
  $Mbde = Safe-Run { manage-bde -status C: 2>$null }
  if ($Mbde) {
    if ($Mbde -match "Protection Status:\s+Protection On") {
      Add-Finding ([ref]$Findings) (New-Finding INFO "BitLocker aktiv (manage-bde)" "Protection On laut manage-bde -status C:")
      $BitlockerFindingDone = $true
    }
    elseif ($Mbde -match "Protection Status:\s+Protection Off") {
      Add-Finding ([ref]$Findings) (New-Finding MED "BitLocker AUS (manage-bde)" "Protection Off laut manage-bde -status C: -- Empfehlung: aktivieren")
      $BitlockerFindingDone = $true
    }
  }
}

if (-not $BitlockerFindingDone) {
  Add-Finding ([ref]$Findings) (New-Finding INFO "BitLocker Status nicht ermittelbar" "Cmdlets/Feature evtl. nicht vorhanden (z.B. Windows Home). Wenn verfuegbar: BitLocker oder Geraeteverschluesselung aktivieren.")
}
# ----------------------- scoring + dashboard -----------------------
$Score = 0
foreach ($f in $Findings) { $Score += Severity-Score $f.Severity }
if ($Score -gt 100) { $Score = 100 }

$RiskLabel = if ($Score -ge 80) { "KRITISCH" }
elseif ($Score -ge 50) { "HOCH" }
elseif ($Score -ge 25) { "MITTEL" }
elseif ($Score -ge 10) { "NIEDRIG" }
else { "OK" }

$Top = $Findings | Sort-Object @{Expression={ Severity-Score $_.Severity }; Descending=$true }, Time | Select-Object -First 8

Write-Header "DASHBOARD"
Write-Host ("RISK SCORE: {0}/100  =>  {1}" -f $Score, $RiskLabel) -ForegroundColor Cyan
Write-Host ("Findings: {0}  |  Runtime: {1}s" -f $Findings.Count, ([int]((Get-Date)-$StartTime).TotalSeconds)) -ForegroundColor DarkGray

Write-Host ""
Write-Host "TOP FINDINGS (kurz):" -ForegroundColor Yellow
$Top | Select-Object Severity, Title, @{n="Details";e={ Short $_.Details 120 }} | Format-Table -AutoSize | Out-String | Tee-Object -FilePath $TxtPath -Append | Write-Host

# ----------------------- export JSON -----------------------
$Export = [pscustomobject]@{
  Meta = [pscustomobject]@{
    Computer   = $Computer
    User       = $User
    Time       = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    IsAdmin    = $IsAdmin
    RiskScore  = $Score
    RiskLabel  = $RiskLabel
    ReportDir  = $OutDir
  }
  Findings = $Findings
}
$Export | ConvertTo-Json -Depth 6 | Set-Content -Encoding UTF8 -Path $JsonPath

# ----------------------- export HTML -----------------------
$style = @"
<style>
body{font-family:Segoe UI,Arial,sans-serif;margin:20px;}
h1{margin:0 0 10px 0;}
.badge{display:inline-block;padding:4px 10px;border-radius:16px;font-weight:600;}
.ok{background:#e8f5e9;color:#1b5e20;}
.low{background:#e3f2fd;color:#0d47a1;}
.med{background:#fff8e1;color:#e65100;}
.high{background:#ffebee;color:#b71c1c;}
table{border-collapse:collapse;width:100%;margin-top:14px;}
th,td{border:1px solid #ddd;padding:8px;vertical-align:top;}
th{background:#f5f5f5;text-align:left;}
.small{color:#666;font-size:12px;}
</style>
"@

$badgeClass = switch ($RiskLabel) {
  "OK"      { "ok" }
  "NIEDRIG" { "low" }
  "MITTEL"  { "med" }
  default   { "high" }
}

$rows = foreach ($f in ($Findings | Sort-Object @{Expression={ Severity-Score $_.Severity }; Descending=$true }, Time)) {
  "<tr><td>$($f.Time)</td><td>$($f.Severity)</td><td>$([System.Web.HttpUtility]::HtmlEncode($f.Title))</td><td>$([System.Web.HttpUtility]::HtmlEncode($f.Details))</td></tr>"
}

$html = @"
<html><head><meta charset="utf-8">$style</head><body>
<h1>ELITE Scan Report â€” $Computer</h1>
<div class="small">User: $User â€¢ Time: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') â€¢ Admin: $IsAdmin</div>
<p><span class="badge $badgeClass">RISK SCORE: $Score/100 â€” $RiskLabel</span></p>

<h2>Top Findings</h2>
<table>
<tr><th>Time</th><th>Severity</th><th>Title</th><th>Details</th></tr>
$($rows -join "`j")
</table>

<p class="small">Files: JSON=$JsonPath â€¢ TXT=$TxtPath</p>
</body></html>
"@
Set-Content -Encoding UTF8 -Path $HtmlPath -Value $html

