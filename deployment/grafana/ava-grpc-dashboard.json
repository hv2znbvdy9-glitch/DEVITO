{
  "dashboard": {
    "title": "AVA gRPC Server Monitoring",
    "tags": ["ava", "grpc", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "type": "graph",
        "title": "Request Rate (QPS)",
        "targets": [
          {
            "expr": "sum(rate(ava_grpc_requests_total[5m])) by (method)",
            "legendFormat": "{{method}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ],
        "legend": {
          "show": true,
          "values": true,
          "current": true,
          "avg": true
        }
      },
      {
        "id": 2,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "type": "graph",
        "title": "Request Duration (p50, p95, p99)",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(ava_grpc_request_duration_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p50 - {{method}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(ava_grpc_request_duration_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p95 - {{method}}",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(ava_grpc_request_duration_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p99 - {{method}}",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "type": "stat",
        "title": "Success Rate",
        "targets": [
          {
            "expr": "sum(rate(ava_grpc_requests_total{status=\"OK\"}[5m])) / sum(rate(ava_grpc_requests_total[5m])) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 95, "color": "yellow"},
                {"value": 99, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "type": "stat",
        "title": "Active Requests",
        "targets": [
          {
            "expr": "sum(ava_grpc_active_requests)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 100, "color": "yellow"},
                {"value": 500, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "type": "stat",
        "title": "Active Connections",
        "targets": [
          {
            "expr": "ava_grpc_active_connections",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 100, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "type": "graph",
        "title": "Error Rate by Method",
        "targets": [
          {
            "expr": "sum(rate(ava_grpc_errors_total[5m])) by (method, code)",
            "legendFormat": "{{method}} - {{code}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Errors/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "type": "piechart",
        "title": "Request Distribution",
        "targets": [
          {
            "expr": "sum(rate(ava_grpc_requests_total[5m])) by (method)",
            "legendFormat": "{{method}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "type": "graph",
        "title": "Authentication Attempts",
        "targets": [
          {
            "expr": "sum(rate(ava_grpc_auth_attempts_total[5m])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Attempts/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 9,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "type": "graph",
        "title": "Rate Limit Hits",
        "targets": [
          {
            "expr": "sum(rate(ava_grpc_rate_limit_hits_total[5m])) by (user_id)",
            "legendFormat": "{{user_id}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Hits/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "type": "graph",
        "title": "Message Size (Request/Response)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(ava_grpc_request_size_bytes_bucket[5m])) by (le))",
            "legendFormat": "Request p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(ava_grpc_response_size_bytes_bucket[5m])) by (le))",
            "legendFormat": "Response p95",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "bytes", "label": "Size"},
          {"format": "short"}
        ]
      },
      {
        "id": 11,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "type": "stat",
        "title": "Server Uptime",
        "targets": [
          {
            "expr": "ava_grpc_uptime_seconds",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 0
          }
        }
      },
      {
        "id": 12,
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40},
        "type": "table",
        "title": "Top Methods by Request Count",
        "targets": [
          {
            "expr": "topk(10, sum(rate(ava_grpc_requests_total[5m])) by (method))",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {
                "method": "Method",
                "Value": "Requests/sec"
              }
            }
          }
        ]
      },
      {
        "id": 13,
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 48},
        "type": "stat",
        "title": "TLS Cert Expiry",
        "targets": [
          {
            "expr": "ava_grpc_tls_cert_expiry_seconds / 86400",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "days",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 7, "color": "orange"},
                {"value": 30, "color": "yellow"},
                {"value": 60, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 14,
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 48},
        "type": "stat",
        "title": "Total Requests (24h)",
        "targets": [
          {
            "expr": "sum(increase(ava_grpc_requests_total[24h]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 15,
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 48},
        "type": "stat",
        "title": "Avg Request Duration",
        "targets": [
          {
            "expr": "avg(rate(ava_grpc_request_duration_seconds_sum[5m]) / rate(ava_grpc_request_duration_seconds_count[5m]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "decimals": 2
          }
        }
      },
      {
        "id": 16,
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 48},
        "type": "stat",
        "title": "Error Rate",
        "targets": [
          {
            "expr": "sum(rate(ava_grpc_errors_total[5m])) / sum(rate(ava_grpc_requests_total[5m])) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "namespace",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(ava_grpc_requests_total, namespace)",
          "current": {
            "value": "ava-system"
          }
        },
        {
          "name": "pod",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(ava_grpc_requests_total{namespace=\"$namespace\"}, pod)",
          "multi": true,
          "includeAll": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "Prometheus",
          "enable": true,
          "expr": "changes(ava_grpc_uptime_seconds[5m]) > 0",
          "iconColor": "blue"
        }
      ]
    }
  }
}

